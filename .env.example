# ── Database ──────────────────────────────────────────────────────────────────
MSSQL_SA_PASSWORD=YourStrongPassword!123
MSSQL_PID=Express

# ── Backend API ───────────────────────────────────────────────────────────────
BACKEND_PORT=8080
ASPNETCORE_ENVIRONMENT=Production

# Connection string (injected into backend container)
ConnectionStrings__DefaultConnection=Server=db,1433;Database=OwnDelivery;User Id=sa;Password=YourStrongPassword!123;TrustServerCertificate=true;

# JWT
Jwt__Key=REPLACE_WITH_32_CHAR_SECRET_KEY_HERE
Jwt__Issuer=OwnDeliveryApi
Jwt__Audience=OwnDeliveryClients
Jwt__AccessTokenExpirationMinutes=60
Jwt__RefreshTokenExpirationDays=30

# ── Design / Storybook ────────────────────────────────────────────────────────
DESIGN_PORT=6006

# ── Nginx (reverse proxy) ─────────────────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ── GitHub repos (used by deploy scripts) ─────────────────────────────────────
GITHUB_ORG=your-github-org
BACKEND_REPO=own-delivery-backend
COURIER_APP_REPO=own-delivery-courier-app
DESIGN_REPO=own-delivery-design
INFRA_REPO=own-delivery-infra
